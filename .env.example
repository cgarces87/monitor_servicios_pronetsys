# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor_pronetsys?schema=public"

# Timeout por chequeo HTTP (milisegundos). Si una URL no responde en este tiempo se marca como DOWN.
HTTP_TIMEOUT_MS=10000

# User-Agent que enviara el monitor en cada peticion
HTTP_USER_AGENT="PronetsysMonitor/0.1 (+https://monitor.pronetsys.com.co)"

# Expresion cron del motor. 6 campos (el 1ro son segundos). Default cada 15s,
# para poder honrar intervalos por servicio desde 15s. Cada servicio define su
# propio intervalo (en segundos); el motor lo respeta comparando ultimo_check_en.
MONITOR_CRON="*/15 * * * * *"

# Zona horaria para los logs y el cron
TZ="America/Bogota"

# ---------------------------------------------------------------------------
# Integracion GLPI (Fase 2)
# ---------------------------------------------------------------------------
# Si todas las variables de abajo estan vacias, el monitor sigue funcionando
# pero no creara tickets — solo loguea el stub "[ALERTA] Preparando webhook...".

# URL base de la API REST de GLPI (incluyendo "apirest.php")
GLPI_URL="https://soporte.pronetsys.com.co/glpi/apirest.php"

# App-Token: Setup > General > API > "Add API client" > copia el App token.
GLPI_APP_TOKEN=""

# User-Token: en el perfil del usuario "bot" del monitor > Personalization >
# "Remote access keys" > Regenerate.
GLPI_USER_TOKEN=""

# Entity (organizacion) donde se abriran los tickets. 0 = entidad raiz.
GLPI_ENTITY_ID=0

# (opcional) ID de la categoria ITIL para los tickets. Dejar vacio para usar
# la categoria por defecto que tenga el usuario en GLPI.
GLPI_TICKET_CATEGORY_ID=

# Urgencia / impacto por defecto. Rango 1..5 (5 = critico).
GLPI_DEFAULT_URGENCY=4
GLPI_DEFAULT_IMPACT=4

# Timeout para llamadas HTTP a GLPI (ms).
GLPI_TIMEOUT_MS=15000

# Estado al recuperar el servicio:
#   "solved"  -> deja el ticket en "Resuelto" (5) para que la mesa confirme.
#   "closed"  -> cierra el ticket automaticamente (status 6).
GLPI_AUTO_RESOLVE_AS="solved"

# ---------------------------------------------------------------------------
# API HTTP de lectura (Fase 3) — alimenta el frontend
# ---------------------------------------------------------------------------
# Habilitar/deshabilitar el servidor HTTP embebido en el motor.
API_ENABLED=true

# Puerto y host donde escucha la API. Detras de Nginx se deja en localhost.
API_PORT=3000
API_HOST=127.0.0.1

# Origen permitido por CORS (solo relevante en desarrollo con Vite).
# En produccion el frontend va servido por Nginx en el mismo dominio.
API_CORS_ORIGIN="http://localhost:5173"

# ---------------------------------------------------------------------------
# Autenticacion (Fase 4) — login con roles ADMIN/VIEWER
# ---------------------------------------------------------------------------
# OBLIGATORIO si la API esta habilitada. Genera uno con: openssl rand -hex 32
AUTH_JWT_SECRET=""
# Duracion de la sesion (formato de vercel/ms: 8h, 1d, 30m...)
AUTH_TOKEN_TTL="8h"
# Cookie Secure: true en produccion (HTTPS). Poner false SOLO para dev http local.
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_NAME="monitor_token"

# ---------------------------------------------------------------------------
# Alertas WhatsApp (Fase 4) — via gateway OpenWA (rmyndharis/OpenWA, NestJS)
# ---------------------------------------------------------------------------
# Si WHATSAPP_ENABLED=false el motor funciona igual, solo no envia WhatsApp.
WHATSAPP_ENABLED=false
# URL base del gateway OpenWA, INCLUYENDO el prefijo /api. Puerto default 2785.
# Ej: http://IP_DEL_SERVIDOR:2785/api
WHATSAPP_API_URL="http://127.0.0.1:2785/api"
# API key de OpenWA (se envia como header X-API-Key). Esta en data/.api-key del gateway.
WHATSAPP_API_KEY=""
# ID (o nombre) de la sesion de WhatsApp ya conectada (QR escaneado) en OpenWA.
WHATSAPP_SESSION_ID=""
# Sufijo de chat: @c.us para contactos individuales, @g.us para grupos.
WHATSAPP_CHAT_SUFFIX="@c.us"
# Destinatarios separados por coma (codigo pais + numero, sin signos).
# Ej: "573001112233,573004445566"
WHATSAPP_RECIPIENTS=""
WHATSAPP_TIMEOUT_MS=15000

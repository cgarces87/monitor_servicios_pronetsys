// Esquema Prisma para el monitor in-house de Pronetsys.
// Fase 1: inventario de servicios, log historico de chequeos y registro de incidentes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  UP
  DOWN
  PAUSED
}

enum MonitorType {
  HTTP
  TCP
}

enum Role {
  ADMIN
  VIEWER
}

// Configuracion de notificaciones (singleton, fila id=1).
model NotificacionConfig {
  id                    Int      @id @default(1)
  whatsappEnabled       Boolean  @default(false) @map("whatsapp_enabled")
  whatsappApiUrl        String?  @map("whatsapp_api_url") @db.VarChar(500)
  whatsappApiKey        String?  @map("whatsapp_api_key") @db.VarChar(500)
  whatsappSessionId     String?  @map("whatsapp_session_id") @db.VarChar(255)
  whatsappChatSuffix    String   @default("@c.us") @map("whatsapp_chat_suffix") @db.VarChar(20)
  whatsappTimeoutMs     Int      @default(15000) @map("whatsapp_timeout_ms")
  notificarCaida        Boolean  @default(true) @map("notificar_caida")
  notificarRecuperacion Boolean  @default(true) @map("notificar_recuperacion")
  actualizadoEn         DateTime @default(now()) @updatedAt @map("actualizado_en")

  @@map("notificacion_config")
}

enum TipoEnvioWhatsapp {
  CAIDA
  RECUPERACION
  PRUEBA
  BIENVENIDA
}

model WhatsappEnvio {
  id                   Int               @id @default(autoincrement())
  tipo                 TipoEnvioWhatsapp
  destinatarioNumero   String            @map("destinatario_numero") @db.VarChar(20)
  destinatarioEtiqueta String?           @map("destinatario_etiqueta") @db.VarChar(80)
  texto                String            @db.VarChar(4000)
  exitoso              Boolean
  errorMsg             String?           @map("error_msg") @db.VarChar(500)
  serviceId            Int?              @map("service_id")     // sin FK: queremos historial aunque se borre el servicio
  incidentId           Int?              @map("incident_id")
  timestamp            DateTime          @default(now())

  @@index([timestamp])
  @@map("whatsapp_envios")
}

model WhatsappRecipient {
  id                Int       @id @default(autoincrement())
  numero            String    @db.VarChar(20)             // codigo pais + numero, sin signos
  etiqueta          String?   @db.VarChar(80)             // nombre opcional
  activo            Boolean   @default(true)
  bienvenidaEnviada Boolean   @default(false) @map("bienvenida_enviada") // true cuando se le confirmo la activacion
  bienvenidaEn      DateTime? @map("bienvenida_en")
  creadoEn          DateTime  @default(now()) @map("creado_en")

  servicios WhatsappRecipientService[]   // si esta vacio = catch-all (recibe alertas de todos)

  @@map("whatsapp_recipients")
}

// Suscripcion de un destinatario a un servicio especifico.
// Si un destinatario NO tiene filas aqui -> recibe alertas de TODOS los servicios.
// Si tiene filas -> solo recibe de los servicios listados.
model WhatsappRecipientService {
  recipientId Int @map("recipient_id")
  serviceId   Int @map("service_id")

  recipient WhatsappRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  service   Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([recipientId, serviceId])
  @@index([serviceId])
  @@map("whatsapp_recipient_services")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(80)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(VIEWER)
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")

  @@map("users")
}

model Service {
  id                  Int           @id @default(autoincrement())
  nombre              String        @db.VarChar(150)
  tipo                MonitorType   @default(HTTP)
  url                 String?       @db.VarChar(500)        // usado si tipo = HTTP
  host                String?       @db.VarChar(255)        // usado si tipo = TCP
  puerto              Int?                                  // usado si tipo = TCP
  intervaloMonitoreo  Int           @default(60) @map("intervalo_monitoreo") // en SEGUNDOS (min 15, max 86400 = 24h)
  estadoActual        ServiceStatus @default(UP) @map("estado_actual")
  creadoEn            DateTime      @default(now()) @map("creado_en")
  ultimoCheckEn       DateTime?     @map("ultimo_check_en")

  logs                 Log[]
  incidentes           Incident[]
  destinatariosWhatsapp WhatsappRecipientService[]

  @@index([estadoActual])
  @@map("services")
}

model Log {
  id         BigInt   @id @default(autoincrement())
  serviceId  Int      @map("service_id")
  latenciaMs Int      @map("latencia_ms")
  statusCode Int?     @map("status_code")
  errorMsg   String?  @map("error_msg") @db.VarChar(500)
  timestamp  DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, timestamp])
  @@map("logs")
}

model Incident {
  id                Int       @id @default(autoincrement())
  serviceId         Int       @map("service_id")
  horaCaida         DateTime  @default(now()) @map("hora_caida")
  horaRecuperacion  DateTime? @map("hora_recuperacion")
  detalleError      String?   @map("detalle_error") @db.VarChar(1000)
  glpiTicketId      Int?      @map("glpi_ticket_id")
  glpiEstado        Int?      @map("glpi_estado")              // status del ticket en GLPI (1..6)
  glpiEstadoSyncEn  DateTime? @map("glpi_estado_sync_en")     // ultima sincronizacion desde GLPI

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Solo puede existir UN incidente abierto (horaRecuperacion = null) por servicio.
  // Esto se aplica por logica de aplicacion en stateManager.ts.
  @@index([serviceId, horaRecuperacion])
  @@map("incidents")
}
